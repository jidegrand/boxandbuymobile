PORT=4000
AUTH_PROVIDER=prestashop
JWT_SECRET=replace-with-a-64-character-random-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
JWT_ISSUER=boxandbuy-mobile-api
JWT_AUDIENCE=boxandbuy-mobile
